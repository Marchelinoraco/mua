# Database (Neon PostgreSQL)
# Runtime (PrismaService) — WAJIB pakai connection string pooled (PgBouncer, "-pooler")
# karena serverless membuka banyak koneksi pendek.
# Contoh: postgresql://<user>:<password>@ep-xxxx-pooler.ap-southeast-1.aws.neon.tech/glowbook?sslmode=require
DATABASE_URL="postgresql://glowbook:glowbook@localhost:5432/glowbook_dev"

# Migrasi (`prisma migrate deploy`/`dev`, lihat prisma.config.ts) — WAJIB pakai connection
# string direct (bukan pooler) karena migrasi butuh session lock yang tidak didukung PgBouncer.
# Contoh: postgresql://<user>:<password>@ep-xxxx.ap-southeast-1.aws.neon.tech/glowbook?sslmode=require
# Kosongkan/hapus untuk dev lokal tanpa Neon — akan fallback ke DATABASE_URL.
DIRECT_DATABASE_URL=""

# JWT
JWT_SECRET="change-me-use-a-long-random-secret"
JWT_EXPIRES_IN="7d"

# CORS — origin frontend yang diizinkan (produksi: domain Vercel frontend)
CORS_ORIGIN="http://localhost:5173"

# App
PORT=3000
NODE_ENV="development"

# Vercel Blob — penyimpanan bukti transfer klien (F06, RULE-1 nol kustodi:
# yang disimpan hanya GAMBAR/PDF bukti, bukan dana). Dibaca otomatis oleh SDK
# @vercel/blob dari process.env (lihat backend/src/payments/blob-storage.service.ts).
# Provisioning: `vercel blob store create` lalu `vercel env pull` (atau salin
# token dari dashboard Vercel > Storage > Blob). Tanpa ini, app tetap bisa
# boot & endpoint non-upload (mark-cash/confirm/reject) tetap jalan — hanya
# POST /bookings/:kode/payments (upload bukti) yang akan gagal 500.
BLOB_READ_WRITE_TOKEN=""
